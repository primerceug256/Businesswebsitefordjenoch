# Payment System Environment Variables
# Copy this file to .env.local and fill in your actual values

# ==================== STRIPE CONFIGURATION ====================
# Required for automatic Stripe payments

# Get from Stripe Dashboard → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# This is stored in Supabase secrets (not in .env.local)
# Use: supabase secrets set STRIPE_SECRET_KEY=sk_test_...
# STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# Webhook secret for verifying Stripe events
# Use: supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE


# ==================== EMAIL SERVICE CONFIGURATION ====================
# Optional - for sending payment notifications

# Email service provider: resend, sendgrid, mailgun
EMAIL_SERVICE_PROVIDER=resend

# API key for email service
# For Resend: Get from https://resend.com/api-keys
# For SendGrid: Get from https://app.sendgrid.com/settings/api_keys
# For Mailgun: Get from https://app.mailgun.com/app/account/security/api_keys
EMAIL_API_KEY=your_email_api_key_here

# Email addresses for notifications
ADMIN_EMAIL=admin@djenoch.com
SUPPORT_EMAIL=support@djenoch.com
FROM_EMAIL=noreply@djenoch.com


# ==================== APPLICATION CONFIGURATION ====================

# Your application URL
APP_URL=http://localhost:5173

# Environment: development, staging, production
ENVIRONMENT=development

# Enable debug logging
DEBUG=false


# ==================== AIRTEL MONEY CONFIGURATION ====================
# For manual Airtel Money payments

AIRTEL_PHONE=+256747816444
AIRTEL_BUSINESS_NAME=DJ ENOCH PRO


# ==================== RATE LIMITING ====================

# Maximum payment submissions per minute per user
MAX_PAYMENTS_PER_MINUTE=5

# Duplicate submission prevention window (seconds)
DUPLICATE_PREVENTION_SECONDS=30


# ==================== SECURITY ====================

# JWT signing key for payment receipts
JWT_SECRET=your_jwt_secret_key_here

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,https://yourdomain.com


# ==================== NOTES ====================
# - Keep STRIPE_SECRET_KEY and EMAIL_API_KEY secret
# - Use .env.local for local development
# - Use Supabase secrets for production
# - Public keys like VITE_STRIPE_PUBLISHABLE_KEY can be in .env.local
